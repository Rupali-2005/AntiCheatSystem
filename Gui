    private JLabel styledLabel(String text, int size, int style, Color color) {
        JLabel l = new JLabel(text);
        l.setFont(new Font("Segoe UI", style, size));
        l.setForeground(color);
        return l;
    }

    private Font uiFont(int size, int style) {
        return new Font("Segoe UI", style, size);
    }

    private GridBagConstraints gbc(int x, int y, int width) {
        GridBagConstraints g = new GridBagConstraints();
        g.gridx = x; g.gridy = y; g.gridwidth = width;
        g.fill  = GridBagConstraints.HORIZONTAL;
        g.insets = new Insets(4, 4, 4, 4);
        return g;
    }

    private void addRow(JPanel card, GridBagConstraints g, String labelText, JComponent comp) {
        JLabel lbl = new JLabel(labelText);
        lbl.setFont(uiFont(12, Font.PLAIN));
        lbl.setForeground(TEXT_DIM);
        g.gridwidth = 2; g.gridx = 0;
        card.add(lbl, g);  g.gridy++;
        card.add(comp, g); g.gridy++;
    }

    private class StatusRenderer extends DefaultTableCellRenderer {
        
        public Component getTableCellRendererComponent(
                JTable table, Object value, boolean selected,
                boolean focus, int row, int col) {
            JLabel cell = (JLabel) super.getTableCellRendererComponent(
                table, value, selected, focus, row, col);
            String s = value != null ? value.toString() : "";
            cell.setFont(uiFont(12, Font.BOLD));
            cell.setForeground(statusColor(s));
            if (!selected) cell.setBackground(BG_CARD);
            return cell;
        }
    }

    public static void main(String[] args) {
        try { UIManager.setLookAndFeel(UIManager.getCrossPlatformLookAndFeelClassName()); }
        catch (Exception ignored) {}

        SwingUtilities.invokeLater(() -> new AntiCheatGUI().setVisible(true));
    }

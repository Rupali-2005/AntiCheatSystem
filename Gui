    public AntiCheatGUI() {
        engine = new AntiCheatEngine();
        queue  = new ActionQueue();
        server = new GameServer(queue, engine);

        Thread serverThread = new Thread(server, "GameServer-Thread");
        serverThread.setDaemon(true);
        serverThread.start();

        buildFrame();
        buildUI();
        startAutoRefresh();

        addWindowListener(new WindowAdapter() {
             public void windowClosing(WindowEvent e) {
                server.stop();
                refreshTimer.stop();
                dispose();
                System.exit(0);
            }
        });
    }


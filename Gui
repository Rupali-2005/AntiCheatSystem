    private void doSubmit(boolean enqueue) {
        String pid  = actionPlayerField.getText().trim();
        String type = (String) actionTypeCombo.getSelectedItem();
        String valS = actionValueField.getText().trim();

        if (pid.isEmpty())  { log("Player ID is required.");    return; }
        if (valS.isEmpty()) { log("Value is required.");         return; }

        double value;
        try { value = Double.parseDouble(valS); }
        catch (NumberFormatException ex) { log("Invalid value: " + valS); return; }

        Action action = new Action(pid, type, System.currentTimeMillis(), value);

        if (enqueue) {
            if (!ActionValidator.isValid(action)) {
                log("REJECTED before queuing: " + ActionValidator.getInvalidReason(action));
                return;
            }
            queue.enqueue(action);
            log("⏎  Queued  [" + pid + "  " + type + "  " + value + "]");
        } else {
            RiskResult result = engine.evaluate(action);
            boolean flagged   = !result.lastRule.equals("CLEAN");
            String icon       = flagged ? "⚠  FLAGGED" : "✓  CLEAN  ";
            log(icon + "  |  " + result);
        }

        SwingUtilities.invokeLater(this::refreshTable);
    }

    /** Show status in console. */
    private void doStatus() {
        String pid = lookupPlayerField.getText().trim();
        if (pid.isEmpty()) { log("Enter a Player ID first."); return; }

        PlayerRecord rec = engine.getPlayerRecord(pid);
        if (rec == null) { log("No record found for: " + pid); return; }

        StringBuilder sb = new StringBuilder();
        sb.append("── ").append(rec.playerId).append(" ──\n");
        sb.append("   Status:     ").append(rec.getStatus()).append("\n");
        sb.append("   Risk Score: ").append(rec.getRiskScore()).append("\n");
        sb.append("   Violations: ").append(rec.getViolationCount()).append("\n");
        for (RuleViolation v : rec.getViolations())
            sb.append("   • ").append(v).append("\n");
        log(sb.toString());
    }

    private void doReset() {
        String pid = lookupPlayerField.getText().trim();
        if (pid.isEmpty()) { log("Enter a Player ID to reset."); return; }

        int choice = JOptionPane.showConfirmDialog(
            this,
            "Reset all violation data for player \"" + pid + "\"?",
            "Confirm Reset",
            JOptionPane.YES_NO_OPTION,
            JOptionPane.WARNING_MESSAGE
        );
        if (choice == JOptionPane.YES_OPTION) {
            engine.resetPlayer(pid);
            log("Reset record for: " + pid);
            refreshTable();
        }
    }

    private void refreshTable() {
        HashMap<String, PlayerRecord> all = engine.getAllRecords();
        tableModel.setRowCount(0);

        for (PlayerRecord r : all.values()) {
            ArrayList<RuleViolation> vs = r.getViolations();
            String last = vs.isEmpty() ? "—" : vs.get(vs.size() - 1).ruleName;
            tableModel.addRow(new Object[]{
                r.playerId,
                r.getStatus(),
                r.getRiskScore(),
                r.getViolationCount(),
                last
            });
        }
    }

    private void refreshLog() {
    File file = new File("violations.log");
    if (!file.exists()) {
        logArea.setText("No violation log file found (violations.log).");
        return;
    }
    SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
    StringBuilder sb = new StringBuilder();
    try (BufferedReader br = new BufferedReader(new FileReader(file))) {
        String line;
        while ((line = br.readLine()) != null) {
            if (line.startsWith("---") || line.trim().isEmpty()) {
                sb.append(line).append("\n");
                continue;
            }
            String[] parts = line.split("\\|");
            if (parts.length == 5) {
                try {
                    long ts = Long.parseLong(parts[3].trim());
                    parts[3] = sdf.format(new Date(ts));
                } catch (NumberFormatException ignored) {}
            }
            sb.append(String.join(" | ", parts)).append("\n");
        }
    } catch (IOException ex) {
        sb.append("Error reading log: ").append(ex.getMessage());
    }
    logArea.setText(sb.toString());
    logArea.setCaretPosition(logArea.getDocument().getLength());
}


    private void saveConfig() {
        try {
            CheatConfig.SPEED_THRESHOLD    = Double.parseDouble(cfSpeed.getText().trim());
            CheatConfig.SCORE_THRESHOLD    = Double.parseDouble(cfScore.getText().trim());
            CheatConfig.TELEPORT_THRESHOLD = Double.parseDouble(cfTeleport.getText().trim());
            CheatConfig.AIMBOT_WINDOW      = (int) Double.parseDouble(cfAimbot.getText().trim());
            CheatConfig.SUSPICIOUS_SCORE   = (int) Double.parseDouble(cfSusp.getText().trim());
            CheatConfig.BLOCKED_SCORE      = (int) Double.parseDouble(cfBlocked.getText().trim());
            log("✓  Configuration saved successfully.");
            JOptionPane.showMessageDialog(
                this, "Thresholds updated.", "Saved", JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException ex) {
            log("Invalid config value: " + ex.getMessage());
            JOptionPane.showMessageDialog(
                this, "Invalid value: " + ex.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private void showDetail(String pid) {
        PlayerRecord rec = engine.getPlayerRecord(pid);
        if (rec == null) return;

        JDialog dlg = new JDialog(this, "Player Detail: " + pid, true);
        dlg.setSize(520, 380);
        dlg.setLocationRelativeTo(this);
        dlg.getContentPane().setBackground(BG_PANEL);
        dlg.setLayout(new BorderLayout());

        // Mini header
        JPanel hdr = new JPanel(new FlowLayout(FlowLayout.LEFT, 12, 10));
        hdr.setBackground(BG_DARK);

        Color sc = statusColor(rec.getStatus());
        hdr.add(styledLabel("  " + pid,                   15, Font.BOLD,  TEXT_PRIMARY));
        hdr.add(styledLabel("● " + rec.getStatus(),       13, Font.BOLD,  sc));
        hdr.add(styledLabel("Risk: " + rec.getRiskScore(), 13, Font.PLAIN, TEXT_DIM));

        String[] cols = {"Rule", "Severity", "Weight", "Value", "Time"};
        DefaultTableModel dm = new DefaultTableModel(cols, 0) {
             public boolean isCellEditable(int r, int c) { return false; }
        };
        SimpleDateFormat sdf = new SimpleDateFormat("HH:mm:ss");
        for (RuleViolation v : rec.getViolations())
            dm.addRow(new Object[]{
                v.ruleName,
                v.severity.name(),
                "+" + v.severity.weight,
                String.format("%.2f", v.actionValue),
                sdf.format(new Date(v.timestamp))
            });

        JTable t = new JTable(dm);
        t.setBackground(BG_CARD);
        t.setForeground(TEXT_PRIMARY);
        t.setGridColor(BORDER_CLR);
        t.setRowHeight(26);
        t.setFont(uiFont(12, Font.PLAIN));
        t.setShowHorizontalLines(true);
        t.setShowVerticalLines(false);
        t.getTableHeader().setBackground(BG_DARK);
        t.getTableHeader().setForeground(ACCENT);
        t.getTableHeader().setFont(uiFont(12, Font.BOLD));

        t.getColumnModel().getColumn(1).setCellRenderer(new DefaultTableCellRenderer() {
             public Component getTableCellRendererComponent(
                    JTable table, Object value, boolean sel, boolean foc, int r, int c) {
                JLabel lbl = (JLabel) super.getTableCellRendererComponent(
                    table, value, sel, foc, r, c);
                lbl.setForeground(severityColor(value != null ? value.toString() : ""));
                if (!sel) lbl.setBackground(BG_CARD);
                lbl.setFont(uiFont(12, Font.BOLD));
                return lbl;
            }
        });

        JScrollPane scroll = new JScrollPane(t);
        scroll.getViewport().setBackground(BG_CARD);
        scroll.setBorder(BorderFactory.createEmptyBorder());

        dlg.add(hdr,    BorderLayout.NORTH);
        dlg.add(scroll, BorderLayout.CENTER);
        dlg.setVisible(true);
    }

    private void startAutoRefresh() {
        refreshTimer = new javax.swing.Timer(2500, e -> refreshTable());
        refreshTimer.start();
    }

    private void log(String msg) {
        SwingUtilities.invokeLater(() -> {
            consoleArea.append(msg + "\n");
            consoleArea.setCaretPosition(consoleArea.getDocument().getLength());
        });
    }

    private Color statusColor(String s) {
        if ("BLOCKED".equals(s))    return COL_BLOCKED;
        if ("SUSPICIOUS".equals(s)) return COL_SUSP;
        return COL_SAFE;
    }

    private Color severityColor(String s) {
        switch (s) {
            case "CRITICAL": return COL_BLOCKED;
            case "HIGH":     return new Color(240, 140, 60);
            case "MEDIUM":   return COL_SUSP;
            default:         return COL_SAFE;
        }
    }


            {"TELEPORT_THRESHOLD", String.valueOf(CheatConfig.TELEPORT_THRESHOLD),
                "Max positional delta before Teleport fires"},
            {"AIMBOT_WINDOW",      String.valueOf(CheatConfig.AIMBOT_WINDOW),
                "Consecutive perfect shots required for Aimbot"},
            {"SUSPICIOUS_SCORE",   String.valueOf(CheatConfig.SUSPICIOUS_SCORE),
                "Risk score threshold for SUSPICIOUS status"},
            {"BLOCKED_SCORE",      String.valueOf(CheatConfig.BLOCKED_SCORE),
